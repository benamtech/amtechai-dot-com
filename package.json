{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run skills:build && npm run okf:build && vite build",
    "postbuild": "node scripts/okf/prerender.ts && node scripts/seo/validate-seo.ts",
    "okf:prerender": "node scripts/okf/prerender.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "okf:build": "node scripts/okf/build-okf.ts",
    "okf:validate": "node scripts/okf/validate-okf.ts",
    "okf:validate:phase3": "node scripts/okf/validate-okf.ts --phase=3",
    "okf:db:seed-sql": "node scripts/okf/db-seed-sql.ts",
    "okf:db:verify": "node scripts/okf/db-verify.ts",
    "okf:check": "npm run okf:build && npm run okf:validate",
    "skills:build": "node scripts/skills/build-skills.ts",
    "skills:conformance": "node scripts/skills/run-conformance.ts",
    "skills:validate": "node scripts/skills/validate-skills.ts",
    "skills:verify": "node scripts/signing/verify-skill.ts",
    "skills:publish": "node scripts/skills/publish-skill.ts",
    "skills:test": "node --test scripts/skills/__fixtures__/*.test.ts",
    "skills:check": "npm run skills:build && npm run okf:build && npm run skills:validate && npm run skills:test",
    "signing:keygen": "node scripts/signing/generate-key.ts",
    "signing:rotate": "node scripts/signing/rotate-key.ts",
    "signing:commit-keygen": "node scripts/signing/generate-commit-key.ts",
    "skills:sign": "npm run skills:conformance && AMTECH_ALLOW_UNSIGNED_BUILD=1 npm run skills:build && node scripts/signing/sign-skills.ts && node scripts/signing/sign-authority.ts && node scripts/signing/sign-anchor.ts && npm run skills:build && npm run skills:validate",
    "artifact:sign": "node scripts/signing/sign-artifact.ts",
    "artifact:verify": "node scripts/signing/verify-artifact.ts",
    "ai:local:setup": "cd AI_EMPLOYEE_MVP/ai-employee-all-files && scripts/setup_local_pc.sh",
    "ai:local:check": "cd AI_EMPLOYEE_MVP/ai-employee-all-files && if [ -d .venv ]; then . .venv/bin/activate; fi && if [ -f .env.provision-hook ]; then set -a; . ./.env.provision-hook; set +a; fi && scripts/check_local_setup.py",
    "ai:caddy:render": "cd AI_EMPLOYEE_MVP/ai-employee-all-files && scripts/install_caddy_config.sh",
    "ai:claim:smoke": "cd AI_EMPLOYEE_MVP/ai-employee-all-files && node scripts/smoke_claim_function.mjs",
    "ai:sms:smoke": "cd AI_EMPLOYEE_MVP/ai-employee-all-files && node scripts/smoke_sms_entry.mjs",
    "ai:claim:secret": "cd AI_EMPLOYEE_MVP/ai-employee-all-files && node scripts/generate_claim_link_secret.mjs",
    "ai:supabase:push": "AI_EMPLOYEE_MVP/ai-employee-all-files/scripts/apply_supabase_ai_employee_migration.sh",
    "ai:supabase:verify": "cd AI_EMPLOYEE_MVP/ai-employee-all-files && node scripts/verify_supabase_claim_table.mjs",
    "ai:provision:dry-run": "python3 AI_EMPLOYEE_MVP/ai-employee-all-files/scripts/provision_client.py --manifest AI_EMPLOYEE_MVP/ai-employee-all-files/schema/client-manifest.example.json --dry-run",
    "seo:validate": "node scripts/seo/validate-seo.ts",
    "seo:check": "npm run build && npm run seo:validate"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.1.0",
    "@supabase/supabase-js": "^2.57.4",
    "@types/three": "^0.184.1",
    "framer-motion": "^12.34.0",
    "gsap": "^3.15.0",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "ajv": "^8.20.0",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
