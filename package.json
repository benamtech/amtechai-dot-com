{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "ai:local:setup": "cd AI_EMPLOYEE_MVP/ai-employee-all-files && scripts/setup_local_pc.sh",
    "ai:local:check": "cd AI_EMPLOYEE_MVP/ai-employee-all-files && scripts/check_local_setup.py",
    "ai:caddy:render": "cd AI_EMPLOYEE_MVP/ai-employee-all-files && scripts/install_caddy_config.sh",
    "ai:claim:smoke": "cd AI_EMPLOYEE_MVP/ai-employee-all-files && node scripts/smoke_claim_function.mjs",
    "ai:sms:smoke": "cd AI_EMPLOYEE_MVP/ai-employee-all-files && node scripts/smoke_sms_entry.mjs",
    "ai:claim:secret": "cd AI_EMPLOYEE_MVP/ai-employee-all-files && node scripts/generate_claim_link_secret.mjs",
    "ai:supabase:push": "AI_EMPLOYEE_MVP/ai-employee-all-files/scripts/apply_supabase_ai_employee_migration.sh",
    "ai:supabase:verify": "cd AI_EMPLOYEE_MVP/ai-employee-all-files && node scripts/verify_supabase_claim_table.mjs",
    "ai:provision:dry-run": "python3 AI_EMPLOYEE_MVP/ai-employee-all-files/scripts/provision_client.py --manifest AI_EMPLOYEE_MVP/ai-employee-all-files/schema/client-manifest.example.json --dry-run"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.1.0",
    "@supabase/supabase-js": "^2.57.4",
    "@types/three": "^0.184.1",
    "framer-motion": "^12.34.0",
    "gsap": "^3.15.0",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
