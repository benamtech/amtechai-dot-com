# Copy to .env.provision-hook on the Hermes host and fill in real values.
# Do not commit the filled file.

PROVISION_HOOK_TOKEN=replace-with-a-long-random-token
PROVISION_HOOK_HOST=127.0.0.1
PROVISION_HOOK_PORT=8787
PROVISION_HOOK_DRY_RUN=0
PROVISION_HOOK_PUBLIC_HOST=hook.agents.amtechai.com
AI_EMPLOYEE_BASE_DOMAIN=agents.amtechai.com
ADMIN_EMAIL=admin@amtechai.com
CADDY_SNIPPET_DIR=
CADDY_RELOAD_COMMAND=

# Required by provision_client.py / claim_number.py when running for real.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
ANTHROPIC_API_KEY=

# Optional but recommended so the local provision hook can mark
# ai_employee_claims as running/provisioned/failed after Netlify accepts a claim.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional enrichment path. Keep off until deterministic output has been reviewed.
AI_EMPLOYEE_ENRICH=0
XAI_API_KEY=

# Optional local placement overrides.
HERMES_ROOT=
AMTECH_WORKSPACES=
