# Add these as Netlify environment variables for the AMTECH site.
# Do not expose server-side values as VITE_ variables.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

PROVISION_HOOK_URL=https://hook.agents.amtechai.com/provision
PROVISION_HOOK_TOKEN=replace-with-the-same-token-as-the-hermes-host

WEB_FORM_URL=https://amtechai.com/claim
TWILIO_SMS_WEBHOOK_URL=https://amtechai.com/sms-entry
CLAIM_ALLOWED_ORIGIN=https://amtechai.com

# Secret that signs the pre-verified text-in claim links (sms-entry mints, claim verifies).
# Use a long random string, e.g. `openssl rand -hex 32`.
CLAIM_LINK_SECRET=

# Local tests only. Do not set these in production.
CLAIM_TEST_MODE=0
SMS_ENTRY_TEST_MODE=0
