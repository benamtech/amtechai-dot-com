# .env for Hermes profile {{CLIENT_ID}} ({{BUSINESS_NAME}})
# Written by provision_client.py.

# Model
ANTHROPIC_API_KEY={{ANTHROPIC_API_KEY}}

# Twilio account credentials (shared across all client profiles)
TWILIO_ACCOUNT_SID={{TWILIO_ACCOUNT_SID}}
TWILIO_AUTH_TOKEN={{TWILIO_AUTH_TOKEN}}

# This client's dedicated agent number (claimed from the pool)
TWILIO_PHONE_NUMBER={{AGENT_PHONE}}

# Public webhook Twilio calls on inbound SMS. Must be reachable and HTTPS.
# Keep signature validation ON: this is the real security boundary, not the
# allowlist. Never set SMS_INSECURE_NO_SIGNATURE outside local debugging.
SMS_WEBHOOK_URL={{WEBHOOK_URL}}
SMS_WEBHOOK_PORT={{WEBHOOK_PORT}}

# Only the supervisor's verified number may talk to this agent.
SMS_ALLOWED_USERS={{CLIENT_PHONE}}

# Where scheduled (cron) messages are delivered.
SMS_HOME_CHANNEL={{CLIENT_PHONE}}

# Timezone for this client's scheduled check-ins (also set on the service).
TZ={{TIMEZONE}}
