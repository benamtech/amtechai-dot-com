# Static response headers (Netlify). Discovery + correct media types for agent payloads.
# Note: per-page rel="alternate" links are baked into each page's <head> (src/lib/seo/*),
# so markdown twins are discoverable without per-path Link headers here.

# OKF knowledge bundle — all Markdown, cache at the edge.
/okf/*
  Content-Type: text/markdown; charset=utf-8
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Canonical-adjacent article Markdown twins (/articles/<slug>.md).
/articles/*.md
  Content-Type: text/markdown; charset=utf-8
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Skill materialized views (markdown + manifests) — cache at the edge.
# Two distinct discovery pointers: Catalog = the list of skills, Authority = the trust root.
/skills/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
  X-Skill-Authority: https://amtechai.com/.well-known/skill-authority.json
  X-Skill-Catalog: https://amtechai.com/skills/index.json

# Machine catalog (amtech-skill-catalog/v1) — the hub's enumerable skill list, readable cross-origin.
/skills/catalog.json
  Content-Type: application/json; charset=utf-8
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Served JSON Schemas for the trust documents — dereferenced by tooling cross-origin.
/skills/schemas/*
  Content-Type: application/schema+json; charset=utf-8
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600

# Domain skill authority trust root + its schema — readable by any agent cross-origin.
/.well-known/skill-authority.json
  Content-Type: application/json; charset=utf-8
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600

/.well-known/skill-authority-v0.json
  Content-Type: application/schema+json; charset=utf-8
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=3600

# Discovery files.
/llms.txt
  Content-Type: text/markdown; charset=utf-8
  Cache-Control: public, max-age=3600
