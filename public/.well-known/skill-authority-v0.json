{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amtechai.com/.well-known/skill-authority-v0.json",
  "title": "AMTECH Skill Authority v0",
  "description": "Schema for the domain-controlled /.well-known/skill-authority.json. It is the trust root: an agent confirms a skill archive sha256 against the entry here, served only from the canonical domain.",
  "type": "object",
  "required": [
    "$schema",
    "authorityUrl",
    "updated",
    "skills"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri",
      "const": "https://amtechai.com/.well-known/skill-authority-v0.json"
    },
    "authorityUrl": {
      "type": "string",
      "format": "uri",
      "description": "Self-reference to this authority file on the canonical domain."
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "slug",
          "name",
          "title",
          "version",
          "status",
          "canonicalUrl",
          "archiveUrl",
          "archiveSha256",
          "authorityUrl"
        ],
        "additionalProperties": false,
        "properties": {
          "slug": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "status": {
            "enum": [
              "published",
              "planned",
              "deprecated"
            ]
          },
          "canonicalUrl": {
            "type": "string",
            "format": "uri"
          },
          "archiveUrl": {
            "type": "string",
            "format": "uri"
          },
          "archiveSha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "authorityUrl": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    }
  }
}
